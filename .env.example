DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin product image uploads (required for media features in admin)
MEDIA_STORAGE_PROVIDER="cloudinary"

# Cloudinary (when MEDIA_STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="bagzillas/products"

# Supabase Storage (server-side uploads; bucket should be public for simple catalogs)
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="product-images"
